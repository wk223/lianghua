{
  "manifest_version": 3,
  "name": "xvqiu - A股短线交易决策助手",
  "version": "1.0.0",
  "description": "四层过滤，帮你少做垃圾机会。",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://push2his.eastmoney.com/*",
    "http://*.eastmoney.com/*",
    "https://*.eastmoney.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://quote.eastmoney.com/*",
        "*://stock.10jqka.com.cn/*"
      ],
      "js": ["content/inject.ts"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "xvqiu - A股短线交易决策助手"
  }
}
